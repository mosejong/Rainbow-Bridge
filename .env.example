# ============================================================
# 레인보우 브릿지 환경 변수 예시
# 사용법: 이 파일을 복사해서 .env 로 만들고 값을 채우세요.
#   (Windows PowerShell) Copy-Item .env.example .env
#   (Mac/Linux)          cp .env.example .env
# .env 는 절대 git에 커밋하지 않습니다 (.gitignore 에 등록됨).
# ============================================================

# ---------- 앱 공통 ----------
# development | production
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ---------- 인증 (JWT) ----------
# 운영 시 반드시 강력한 랜덤 값으로 교체
JWT_SECRET_KEY=rainbow-bridge-secret-change-in-prod
# 토큰 유효 시간 (시간 단위)
JWT_EXPIRE_HOURS=24

# ---------- MongoDB ----------
# Docker Compose 기준: backend 컨테이너에서 MongoDB 서비스명으로 접속
# 로컬에서 Docker 없이 직접 uvicorn을 띄우고 로컬 MongoDB를 쓸 때만 mongodb://localhost:27017 사용
MONGO_URI=mongodb://rainbow_mongo:27017
MONGO_DB_NAME=rainbow_bridge

# ---------- PERSO API (평가/시연용 — 할당량 제한) ----------
PERSO_API_KEY=
PERSO_API_BASE_URL=

# ---------- 개발용 LLM (Gemini) ----------
# 결정(2026-06-02): 로컬 EXAONE → Gemini (강사 권고 + RTX 5060 8GB 제약)
LLM_PROVIDER=gemini
# Gemini OpenAI 호환 엔드포인트
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# 빠르고 한국어 양호 (정확한 태그는 Google AI Studio에서 확인)
LLM_MODEL=gemini-2.5-flash
# 폴백 모델 — 모든 키가 429로 소진되면 이 모델로 한 번 더 재시도(할당량은 모델별 별도).
# 비우면 폴백 없음.
LLM_FALLBACK_MODEL=gemini-1.5-flash
# Google AI Studio 발급 키 (쉼표로 여러 개 설정 시 429 소진 → 자동 다음 키로 전환)
# 예: LLM_API_KEY=AIzaSy...key1,AIzaSy...key2
LLM_API_KEY=

# ---------- RAG / 임베딩 (ChromaDB + Gemini 임베딩) ----------
# 임베딩은 위 LLM_API_KEY·엔드포인트를 재사용합니다(별도 키 불필요).
# 텍스트→벡터 모델 (Gemini)
EMBED_MODEL=gemini-embedding-001
# 임베딩 차원 (0=모델 기본 3072). 작게 줄이면 저장·속도 이점(자동 L2 재정규화)
# ⚠️ 적재(ingest) 후 값을 바꾸면 차원이 안 맞음 → 컬렉션 비우고 재적재 필요
EMBED_DIM=768
# 임베딩 엔드포인트 (기본: LLM_BASE_URL 과 동일 Gemini)
EMBED_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# ChromaDB 로컬 저장 폴더 (git 무시됨)
CHROMA_PERSIST_DIR=ai/rag/_chroma
# 컬렉션 이름 / 검색 top-k
RAG_COLLECTION=consolation
RAG_TOP_K=4
# 위로글 코퍼스 JSON 경로 (팀이 채움; 기본은 샘플 자리표시)
RAG_CORPUS_PATH=ai/rag/data/corpus.sample.json

# ---------- TTS (Google Cloud Text-to-Speech) ----------
# 키 발급: Google Cloud Console → Text-to-Speech API 사용설정
# → 서비스 계정 생성 → 키(JSON) 발급 → 아래 경로에 저장
# 예: ./ai/tts/gcp-tts-key.json
GOOGLE_APPLICATION_CREDENTIALS=
# 한국어 음성
TTS_VOICE=ko-KR-Neural2-A
# Qwen3 TTS GPU 서버 주소 (NCP 백엔드엔 GPU 없음 → 백엔드 /tts 가 이 주소로 HTTP 호출).
# 정환주 GPU 서버에서 ai/tts/server.py(:8002) 실행 후 터널 URL 을 여기 채움.
# 소비처 = 백엔드 /tts (김윤한). 미설정 시 Google TTS(위) 폴백.
TTS_SERVER_URL=

# ---------- LivePortrait / 영상 (멀티모달 가산점) ----------
# local | replicate
LIVEPORTRAIT_MODE=local
# 외부 LivePortrait 설치 경로 (서버는 설치 경로로 지정)
LIVEPORTRAIT_HOME=
# 기본 모션(driving) 영상 경로 — 서버는 올린 driving 영상 경로로 지정
LIVEPORTRAIT_DRIVING=
# 모션 강도 (기본 0.4 — 입 거의 닫힘, 추모 톤)
LIVEPORTRAIT_DRIVING_MULTIPLIER=0.4
# remote 모드(LIVEPORTRAIT_MODE=remote)일 때 터널된 GPU 서비스 주소.
# 확정값(ngrok static domain, 재시작·재발급해도 고정): https://rerun-devious-reaffirm.ngrok-free.dev
# 장민수: 본인 .env 에 위 값을 채우면 remote 추론 연결됨 (.env.example 은 빈 값 유지).
LIVEPORTRAIT_REMOTE_URL=
# replicate fallback 사용 시에만
REPLICATE_API_TOKEN=

# ---------- 안전 라우팅 ----------
# 자살예방상담전화 (고정값 — 변경 금지)
CRISIS_HOTLINE=1393

# ---------- 카카오 ----------
KAKAO_REST_API_KEY=
