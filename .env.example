# ============================================================
# 레인보우 브릿지 환경 변수 예시
# 사용법: 이 파일을 복사해서 .env 로 만들고 값을 채우세요.
#   (Windows PowerShell) Copy-Item .env.example .env
#   (Mac/Linux)          cp .env.example .env
# .env 는 절대 git에 커밋하지 않습니다 (.gitignore 에 등록됨).
# ============================================================

# ---------- 앱 공통 ----------
APP_ENV=development                 # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ---------- MongoDB (김윤한 홈서버) ----------
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=rainbow_bridge

# ---------- PERSO API (평가/시연용 — 할당량 제한) ----------
PERSO_API_KEY=
PERSO_API_BASE_URL=

# ---------- 개발용 LLM (Gemini) ----------
# ※ 결정 변경(2026-06-02): 로컬 EXAONE → Gemini (강사 권고 + RTX 5060 8GB 제약). 상세 ai/llm/MODEL_NOTES.md
LLM_PROVIDER=gemini
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/   # Gemini OpenAI 호환 엔드포인트
LLM_MODEL=gemini-2.5-flash               # 빠르고 한국어 양호 (정확한 태그는 Google AI Studio에서 확인)
LLM_API_KEY=                             # Google AI Studio 발급 키
# (선택) 로컬 폴백 — 오프라인/프라이버시 시: LLM_PROVIDER=ollama, LLM_BASE_URL=http://localhost:11434/v1, LLM_MODEL=exaone3.5:7.8b

# ---------- TTS ----------
TTS_PROVIDER=
TTS_API_KEY=

# ---------- LivePortrait / 영상 (멀티모달 가산점) ----------
LIVEPORTRAIT_MODE=local             # local | replicate
REPLICATE_API_TOKEN=                # replicate fallback 사용 시에만

# ---------- 안전 라우팅 ----------
CRISIS_HOTLINE=1393                 # 자살예방상담전화 (고정)
