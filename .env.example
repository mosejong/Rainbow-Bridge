# ============================================================
# 레인보우 브릿지 환경 변수 예시
# 사용법: 이 파일을 복사해서 .env 로 만들고 값을 채우세요.
#   (Windows PowerShell) Copy-Item .env.example .env
#   (Mac/Linux)          cp .env.example .env
# .env 는 절대 git에 커밋하지 않습니다 (.gitignore 에 등록됨).
# ============================================================

# ---------- 앱 공통 ----------
# development | production
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ---------- 인증 (JWT) ----------
# 운영 시 반드시 강력한 랜덤 값으로 교체
JWT_SECRET_KEY=rainbow-bridge-secret-change-in-prod
# 토큰 유효 시간 (시간 단위)
JWT_EXPIRE_HOURS=24

# ---------- MongoDB ----------
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=rainbow_bridge

# ---------- PERSO API (평가/시연용 — 할당량 제한) ----------
PERSO_API_KEY=
PERSO_API_BASE_URL=

# ---------- 개발용 LLM (Gemini) ----------
# 결정(2026-06-02): 로컬 EXAONE → Gemini (강사 권고 + RTX 5060 8GB 제약)
LLM_PROVIDER=gemini
# Gemini OpenAI 호환 엔드포인트
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# 빠르고 한국어 양호 (정확한 태그는 Google AI Studio에서 확인)
LLM_MODEL=gemini-2.5-flash
# Google AI Studio 발급 키
LLM_API_KEY=

# ---------- RAG / 임베딩 (ChromaDB + Gemini 임베딩) ----------
# 임베딩은 위 LLM_API_KEY·엔드포인트를 재사용합니다(별도 키 불필요).
# 텍스트→벡터 모델 (Gemini)
EMBED_MODEL=gemini-embedding-001
# 임베딩 차원 (0=모델 기본 3072). 작게 줄이면 저장·속도 이점(자동 L2 재정규화)
# ⚠️ 적재(ingest) 후 값을 바꾸면 차원이 안 맞음 → 컬렉션 비우고 재적재 필요
EMBED_DIM=768
# 임베딩 엔드포인트 (기본: LLM_BASE_URL 과 동일 Gemini)
EMBED_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# ChromaDB 로컬 저장 폴더 (git 무시됨)
CHROMA_PERSIST_DIR=ai/rag/_chroma
# 컬렉션 이름 / 검색 top-k
RAG_COLLECTION=consolation
RAG_TOP_K=4
# 위로글 코퍼스 JSON 경로 (팀이 채움; 기본은 샘플 자리표시)
RAG_CORPUS_PATH=ai/rag/data/corpus.sample.json

# ---------- TTS (Google Cloud Text-to-Speech) ----------
# 키 발급: Google Cloud Console → Text-to-Speech API 사용설정
# → 서비스 계정 생성 → 키(JSON) 발급 → 아래 경로에 저장
# 예: ./ai/tts/gcp-tts-key.json
GOOGLE_APPLICATION_CREDENTIALS=
# 한국어 음성
TTS_VOICE=ko-KR-Neural2-A

# ---------- LivePortrait / 영상 (멀티모달 가산점) ----------
# local | replicate
LIVEPORTRAIT_MODE=local
# replicate fallback 사용 시에만
REPLICATE_API_TOKEN=

# ---------- 안전 라우팅 ----------
# 자살예방상담전화 (고정값 — 변경 금지)
CRISIS_HOTLINE=1393

# ---------- 카카오 ----------
KAKAO_REST_API_KEY=
